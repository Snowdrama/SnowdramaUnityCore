{
  "name": "com.snowdrama.core",
  "version": "0.8.0",
  "description": "The core tools I use for my games. This package contains the core tools I use for my games. It is a collection of scripts, shaders, and other assets that I use to speed up my development process.",
  "displayName": "Snowdrama Core Tools",
  "unity": "6000.0",
  "author": {
    "name": "John 'Snowdrama' Close",
    "email": "SnowdramaGames@gmail.com",
    "url": "http://www.snowdrama.net"
  },
  "dependencies": {
    "com.unity.inputsystem": "1.5.0",
    "com.unity.textmeshpro": "3.0.6",
    "com.unity.nuget.newtonsoft-json": "3.0.2",
    "com.unity.cinemachine": "3.1.0"
  },
  "type": "utility",
  "samples": [
    {
      "displayName": "Transition Sample",
      "description": "Shows the use of Transitions",
      "path": "Samples~/TransitionSample"
    },
    {
      "displayName": "Transition Sample",
      "description": "Shows the use of Transitions With the new modal option",
      "path": "Samples~/TransitionWithModalSample"
    },
    {
      "displayName": "Expandable Attribute Sample",
      "description": "Shows the use of Expandable Attribute in the Inspector",
      "path": "Samples~/ExpandableAttributeSample"
    },
    {
      "displayName": "Spring Sample",
      "description": "Shows the use of Springs",
      "path": "Samples~/SpringSample"
    },
    {
      "displayName": "Tag System Sample",
      "description": "Shows the use of TagSystems",
      "path": "Samples~/TagSystemSample"
    },
    {
      "displayName": "Timer Sample",
      "description": "Shows the use of Timers",
      "path": "Samples~/TimerSample"
    },
    {
      "displayName": "UI Router Sample",
      "description": "Shows the use of UIRouters",
      "path": "Samples~/UIRouterMenuSample"
    },
    {
      "displayName": "UI Tools Sample",
      "description": "Shows the use of UITools",
      "path": "Samples~/UIToolsSample"
    },
    {
      "displayName": "Tooltip Sample",
      "description": "Shows the use of the Tooltip Component",
      "path": "Samples~/TooltipSample"
    },
    {
      "displayName": "Virtual Cursor Sample[Experimental]",
      "description": "Shows the use of VirtualCursors",
      "path": "Samples~/VirtualCursorSample"
    },
    {
      "displayName": "UI Curve Sample[Experimental]",
      "description": "Shows the use of UICurves",
      "path": "Samples~/CurvesSample"
    },
    {
      "displayName": "Spline Sample[Experimental]",
      "description": "Shows the use of the Spline Component",
      "path": "Samples~/SplineSample"
    },
    {
      "displayName": "Prefabs: Save & Load",
      "description": "Pre made generic prefabs for all the Save & Load tools",
      "path": "Samples~/SaveLoadPrefabs"
    }
  ]
}